# ~/.zshrc.secrets.template (this can be committed)
# Copy this file to ~/.zshrc.secrets and fill in your actual values

# Used for Claude Code
export GITHUB_PERSONAL_ACCESS_TOKEN="your_token_here"               # https://github.com/settings/personal-access-tokens
export SHADCN_GITHUB_TOKEN="another_token_or_same_as_above"         # https://github.com/settings/tokens
export OBSIDIAN_API_KEY="token_from_local_rest_api_obsidian_plugin" # https://github.com/MarkusPfundstein/mcp-obsidian?tab=readme-ov-file#obsidian-rest-api-key

# Used for Claude Code Telegram Channel
export TELEGRAM_BOT_TOKEN="your_bot_token_here"                    # https://t.me/BotFather

# Google Calendar managed by Claude Code
# To get calendar ID: Google Calendar > Settings > [Your Calendar] > "Integrate calendar" > Calendar ID
export CLAUDE_CALENDAR_ID="your_calendar_id_here"
