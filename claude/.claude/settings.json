{
  "attribution": {
    "commit": ""
  },
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(git ls-tree:*)",
      "Bash(defaults:*)",
      "mcp__obsidian__*",
      "mcp__context7__query-docs",
      "mcp__github__list_pull_requests",
      "WebSearch"
    ],
    "deny": [],
    "defaultMode": "default"
  },
  "model": "opus",
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true
}
